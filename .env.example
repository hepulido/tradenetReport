# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/jobcost_ai

# Session (required)
SESSION_SECRET=your-secure-session-secret-here

# Email Notifications (optional - uses Nodemailer)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password
EMAIL_FROM=JobCost AI <noreply@example.com>

# SMS Notifications (optional - uses Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# QuickBooks Integration (optional)
QB_CLIENT_ID=your-quickbooks-client-id
QB_CLIENT_SECRET=your-quickbooks-client-secret
QB_REDIRECT_URI=http://localhost:5000/api/integrations/quickbooks/callback

# AI Insights (optional - future use)
OPENAI_API_KEY=your-openai-api-key
