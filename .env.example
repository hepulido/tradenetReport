# ===========================================
# JobCost AI - Production Environment Config
# ===========================================
# Copy this file to .env and fill in your values

# ==== DATABASE (Required) ====
# PostgreSQL connection string
# Options: Neon, Supabase, Railway, PlanetScale, etc.
DATABASE_URL=postgresql://user:password@host:5432/jobcost

# ==== FIREBASE AUTH (Required) ====
# Client-side Firebase config (from Firebase Console > Project Settings)
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Server-side Firebase Admin (JSON service account key as single line)
# Download from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"}

# ==== AI/LLM (Required for AI features) ====
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-api03-xxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ==== AWS S3 (Optional - for document storage) ====
# Leave blank to use local storage
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=xxx
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name

# ==== STRIPE (Optional - for billing) ====
# Leave blank if not using paid subscriptions yet
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxx

# ==== EMAIL NOTIFICATIONS (Optional) ====
# SMTP Configuration (works with Gmail, SendGrid, AWS SES, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=JobCost AI <noreply@yourcompany.com>

# ==== SMS NOTIFICATIONS (Optional) ====
# Twilio Configuration
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+15551234567

# ==== QUICKBOOKS (Optional) ====
# QuickBooks OAuth credentials
QB_CLIENT_ID=xxx
QB_CLIENT_SECRET=xxx
QB_REDIRECT_URI=https://yourdomain.com/api/integrations/quickbooks/callback

# ==== SERVER CONFIG ====
# Port is usually set by hosting provider
PORT=5000
NODE_ENV=production

# Session secret for express-session (generate a random string)
SESSION_SECRET=your-random-secret-string-here
